# Server (local PC: DRAW_ENABLED=true | Render: DRAW_ENABLED=false)
PORT=3000
DRAW_ENABLED=true
ADMIN_PASSWORD=your-secure-admin-password
# KNS domain shown on the site (resolved to on-chain wallet for balance/entries)
RAFFLE_ADDRESS=winraffle.kas
RAFFLE_DISPLAY_ADDRESS=winraffle.kas
# Used when KNS API is unavailable
RAFFLE_ONCHAIN_FALLBACK=kaspa:qr3rxmae6r5h9kkt7q5my7rajy492da7cxpy0kkzr99tk3xcydc2uwa3a7u6r
# First day of the raffle (optional, auto-detected from blockchain if omitted)
RAFFLE_LAUNCH_DATE=2026-06-01
POLL_MS=30000

# Auto-payout wallet (must control the raffle address funds)
# Use ONE of these — private key is simplest if exported from Kaspa wallet
WALLET_PRIVATE_KEY=
# WALLET_MNEMONIC=word1 word2 word3 ...

# Optional: where the 10% ops share is sent (defaults to change back to raffle wallet)
OPS_ADDRESS=

# Kaspa network + RPC (local kaspad/kaspa-ng, or public wRPC host)
KASPA_NETWORK=mainnet
KASPA_RPC_URL=127.0.0.1

# Optional: external cron backup (cron-job.org) hits /api/cron/draw?secret=...
CRON_SECRET=